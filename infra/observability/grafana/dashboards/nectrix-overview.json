{
  "title": "Nectrix Overview",
  "uid": "nectrix-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"core-app\"}[1m])) by (le))",
          "legendFormat": "core-app p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(copy_engine_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "copy-engine p95"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"core-app\",status=~\"5..\"}[1m]))",
          "legendFormat": "core-app 5xx/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(copy_engine_http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "copy-engine 5xx/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Stub pipeline synthetic-event throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(copy_engine_stub_events_injected_total[1m])",
          "legendFormat": "events/s"
        }
      ]
    }
  ]
}
