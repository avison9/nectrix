# Local development only. Copy to .env and fill in your own values: cp .env.example .env
# POSTGRES_PASSWORD and MINIO_ROOT_PASSWORD have no default — docker-compose.yml
# will refuse to start until you set them here, in your own untracked .env.
# POSTGRES_APP_PASSWORD also has no default — required before running any
# `make db-*` target (see apps/core-app/db/README.md).

# --- Postgres ---
POSTGRES_USER=nectrix
POSTGRES_PASSWORD=
POSTGRES_DB=nectrix
POSTGRES_PORT=5432
# Password for the restricted `nectrix_app` runtime role (TICKET-004) — created
# by a Liquibase migration, granted CRUD on everything except audit_log
# (INSERT+SELECT only there). Distinct from POSTGRES_PASSWORD (the nectrix
# superuser, used only to run migrations, never by the running app).
POSTGRES_APP_PASSWORD=

# --- Redis ---
REDIS_PORT=6379

# --- Kafka ---
KAFKA_PORT=9092
KAFKA_UI_PORT=8081

# --- MinIO ---
MINIO_ROOT_USER=nectrix
MINIO_ROOT_PASSWORD=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Auth (TICKET-005) ---
# HMAC signing secret for our own HS256 access tokens — no default, generate
# your own (e.g. `openssl rand -base64 64`).
JWT_SIGNING_SECRET=
# Temporary local-key AES-GCM stand-in for TICKET-011's real KMS-backed
# envelope encryption of users.two_factor_secret (e.g. `openssl rand -base64 32`).
TWO_FACTOR_SECRET_ENCRYPTION_KEY=
# Google Cloud Console OAuth 2.0 Web application client — redirect URI must be
# exactly http://localhost:8080/api/v1/auth/oauth/google/callback. See
# apps/core-app/README.md for setup steps. Real end-to-end tested provider.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Apple Sign-In — code path is implemented but NOT end-to-end tested (requires
# a paid Apple Developer account); leave blank unless you have one.
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=
