# Local development only. Copy to .env and fill in your own values: cp .env.example .env
# POSTGRES_PASSWORD and MINIO_ROOT_PASSWORD have no default — docker-compose.yml
# will refuse to start until you set them here, in your own untracked .env.
# POSTGRES_APP_PASSWORD also has no default — required before running any
# `make db-*` target (see apps/core-app/db/README.md).
#
# Every var below is either read by docker-compose.yml (infra container ports/credentials) or by
# apps/core-app's own application.yml (Java) / one of the Go services' main.go (envOr(...)/
# os.Getenv(...)). apps/web and apps/admin-portal have their own separate, already-committed
# apps/web/.env.local and apps/admin-portal/.env.local (Next.js convention) — nothing there needs
# copying from this file.

# --- Postgres ---
POSTGRES_USER=nectrix
POSTGRES_PASSWORD=
POSTGRES_DB=nectrix
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
# Password for the restricted `nectrix_app` runtime role — created
# by a Liquibase migration, granted CRUD on everything except audit_log
# (INSERT+SELECT only there). Distinct from POSTGRES_PASSWORD (the nectrix
# superuser, used only to run migrations, never by the running app).
POSTGRES_APP_PASSWORD=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# standalone|cluster — the local docker-compose redis is always standalone.
REDIS_MODE=standalone
# Comma-separated host:port pairs — cluster mode only, unused locally.
REDIS_CLUSTER_NODES=
# The local docker-compose redis has no requirepass set — leave blank.
REDIS_PASSWORD=

# --- Kafka ---
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_UI_PORT=8081

# --- MinIO ---
MINIO_ROOT_USER=nectrix
MINIO_ROOT_PASSWORD=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- LocalStack ---
# Real AWS KMS API, emulated — apps/core-app/modules/crypto's
# EnvelopeEncryptionService points at this locally instead of real AWS KMS.
# No password/credential needed (LocalStack accepts any dummy value).
LOCALSTACK_PORT=4566
# Bugfix — core-app itself (not docker-compose) needs this too: without it,
# EnvelopeEncryptionService's KMS client falls through to real AWS KMS instead of
# the LocalStack container above, and every broker-account credential
# decrypt fails with a real KmsException ("security token included in the
# request is invalid") since there's no valid real AWS session locally.
# Must match LOCALSTACK_PORT above.
KMS_ENDPOINT_OVERRIDE=http://localhost:4566

# --- AWS region (shared by KMS/archival/documents S3 clients below) ---
AWS_REGION=us-east-1

# --- Broker-account archival (TICKET-101 follow-up) ---
# MinIO-backed cold storage for DISCONNECTED accounts past their retention window.
# access-key/secret-key genuinely validate against MinIO (unlike LocalStack's KMS
# stand-in above) — set them to MINIO_ROOT_USER/MINIO_ROOT_PASSWORD above.
ARCHIVAL_BUCKET=nectrix-archival
ARCHIVAL_ENDPOINT_OVERRIDE=http://localhost:9000
ARCHIVAL_ACCESS_KEY=nectrix
ARCHIVAL_SECRET_KEY=
# Defaults to false — opt-in, same "no test context accidentally fires it" reasoning as
# TOKEN_REFRESH_ENABLED below. 90 days/1 day expressed in seconds.
ARCHIVAL_SWEEP_ENABLED=false
ARCHIVAL_STALE_AFTER_SECONDS=7776000
ARCHIVAL_SWEEP_INTERVAL_SECONDS=86400

# --- Signed management-agreement documents (TICKET-120) ---
# A separate MinIO bucket/prefix from archival's — live documents a Follower fetches on
# demand, not deleted-account history. Same MinIO credentials as archival above.
DOCUMENTS_BUCKET=nectrix-documents
DOCUMENTS_ENDPOINT_OVERRIDE=http://localhost:9000
DOCUMENTS_PUBLIC_ENDPOINT_OVERRIDE=http://localhost:9000
DOCUMENTS_ACCESS_KEY=nectrix
DOCUMENTS_SECRET_KEY=

# --- Auth ---
# HMAC signing secret for our own HS256 access tokens — no default, generate
# your own (e.g. `openssl rand -base64 64`). Must match apps/web/.env.local's and
# apps/admin-portal/.env.local's own JWT_SIGNING_SECRET (both already committed there).
JWT_SIGNING_SECRET=
# Google Cloud Console OAuth 2.0 Web application client — redirect URI must be
# exactly http://localhost:8080/api/v1/auth/oauth/google/callback. See
# apps/core-app/README.md for setup steps. Real end-to-end tested provider.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Apple Sign-In — code path is implemented but NOT end-to-end tested (requires
# a paid Apple Developer account); leave blank unless you have one.
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=

# --- Internal service-to-service auth ---
# Shared secret core-app and every Go service (broker-adapters/copy-engine/
# mt5-bridge-gateway/mt-terminal-host) use to authenticate to each other's internal-only HTTP
# endpoints (SecurityConfig's InternalServiceTokenFilter on the Java side, each Go service's own
# internalapi/httpapi package on the other). No default — generate your own
# (e.g. `openssl rand -base64 32`).
INTERNAL_SERVICE_TOKEN=
# Nectrix-hosted MT5/MT4 terminal-provisioning — a separate secret from
# INTERNAL_SERVICE_TOKEN above, checked by its own, narrower SecurityFilterChain. Only
# apps/mt-terminal-host holds this value. Blank unless you're testing terminal provisioning.
MT_TERMINAL_PROVISIONER_TOKEN=

# --- cTrader Broker Adapter (TICKET-101) ---
# This platform's own registered cTrader Open API application — see
# docs/07-auth-onboarding-broker-linking.md §7.6 for how to obtain these
# (Spotware Connect app registration). Java-side only; apps/broker-adapters
# (Go) never sees this secret, only already-issued OAuth tokens.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
# Must point at the FRONTEND callback page (which captures `code`/`state` and calls core-app's
# POST /callback), not core-app's own backend URL — and must be registered byte-for-byte
# identical as the redirect URI on the Spotware app console for CTRADER_CLIENT_ID above, or
# Spotware rejects it outright.
CTRADER_REDIRECT_URI=http://localhost:3000/broker-accounts/link/ctrader/callback
# Set to true to enable core-app's TokenRefreshJob (@Scheduled) — defaults to
# false so a plain local/CI run never fires real outbound calls to
# openapi.ctrader.com just from loading the Spring context (see
# InvitationsProperties.TokenRefresh's Javadoc). Only meaningful once
# CTRADER_CLIENT_ID/SECRET are set and at least one account is really linked.
TOKEN_REFRESH_ENABLED=false
# Bugfix — periodic account_snapshots writer (fixes analytics' equity curve being
# sparse/stale). Same reasoning as TOKEN_REFRESH_ENABLED above.
ACCOUNT_SNAPSHOT_SCHEDULER_ENABLED=false

# --- Cluster-internal service base URLs ---
# Each Go service's own listen addr (see its main.go's own `addr` const) as core-app/other
# services reach it — all localhost in this local-Docker setup, real k8s Service DNS names in a
# real deployment.
BROKER_ADAPTERS_INTERNAL_BASE_URL=http://localhost:8091
COPY_ENGINE_INTERNAL_BASE_URL=http://localhost:8090
MT5_BRIDGE_GATEWAY_INTERNAL_BASE_URL=http://localhost:8092
MT_TERMINAL_HOST_INTERNAL_BASE_URL=http://localhost:8093
# How every Go service reaches core-app itself.
CORE_APP_INTERNAL_BASE_URL=http://localhost:8080
# TICKET-102 (MT5/MT4 EA-bridge) — the user's own MT4/MT5 terminal dials this address
# DIRECTLY, so it must be reachable from outside the cluster in a real deployment, unlike
# MT5_BRIDGE_GATEWAY_INTERNAL_BASE_URL above.
MT_BRIDGE_GATEWAY_URL=ws://localhost:8092/ea/ws

# --- Invitations ---
# TICKET-118 — the invited Follower's own link points back at apps/web's /accept-invite route.
INVITATION_ACCEPT_URL_BASE=http://localhost:3000/accept-invite

# --- Performance Fee Engine / Billing (TICKET-113/114) ---
PLATFORM_TAKE_RATE_PCT=15.00
# Stripe credentials for the STRIPE_INVOICE collection path + self-serve registration's
# Checkout Session — blank in dev/test, where Stripe calls are statically mocked.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_INDIVIDUAL=
STRIPE_PRICE_PRO=
SUBSCRIPTION_CHECKOUT_SUCCESS_URL=http://localhost:3000/broker-accounts?subscribed=1
SUBSCRIPTION_CHECKOUT_CANCEL_URL=http://localhost:3000/register

# --- Core Notifications (TICKET-115) ---
# Push/email provider config — blank in dev/test (both senders treat a blank value as
# "delivery for this channel is a no-op," not a startup failure).
FIREBASE_SERVICE_ACCOUNT_JSON=
SES_REGION=
SES_SENDER_EMAIL=
# TICKET-118 — local/dev-only escape hatch: when set, bypasses real SES and POSTs to the
# webhook-catcher dev container's /email route instead (see docker-compose.yml's
# webhook-catcher service, WEBHOOK_CATCHER_PORT below). Empty in every real deployment.
LOCAL_EMAIL_CATCHER_URL=http://localhost:9099/email

# --- Engine Control (admin-portal) ---
# Set to true to enable restart/stop/start of broker-adapters/copy-engine/
# mt5-bridge-gateway/mt-terminal-host from the admin-portal's Engine Control page —
# shells out to the local `docker` CLI, so only ever meaningful when core-app itself
# runs directly on the host (not in a container/pod). Defaults to false, same
# opt-in-by-default reasoning as TOKEN_REFRESH_ENABLED above.
ADMIN_SERVICE_CONTROL_ENABLED=false
# Real `docker run --name` values for each engine — must match whatever you actually named
# the containers when starting them locally (see each service's own README for the run command).
BROKER_ADAPTERS_CONTAINER_NAME=nectrix-brokeradapters-run
COPY_ENGINE_CONTAINER_NAME=nectrix-copyengine-run
MT5_BRIDGE_GATEWAY_CONTAINER_NAME=nectrix-mt5bridgegateway-run
MT_TERMINAL_HOST_CONTAINER_NAME=nectrix-mtterminalhost-run

# --- mt-terminal-host (real k8s cluster only, TICKET-something) ---
# Only relevant if you're standing up a real (e.g. kind) cluster to test terminal
# provisioning — not part of the standard local-Docker dev flow (see
# infra/kind/mt-terminal-host-test/run.sh). TERMINAL_IMAGE has no default (mt-terminal-host
# fails fast without it); the rest fall back to sensible in-cluster defaults.
KUBECONFIG=
TERMINAL_NAMESPACE=mt-terminals
TERMINAL_IMAGE=
GATEWAY_HOST=mt5-bridge-gateway.copy-engine.svc.cluster.local
GATEWAY_PORT=8092

# --- copy-engine misc ---
# Only read by copy-engine's own STUB_1_TO_1_COPY-era demo wiring — leave blank unless you
# know you need it (see apps/copy-engine/main.go).
STUB_MASTER_BROKER_ACCOUNT_ID=

# --- Observability (TICKET-010, local dev/CI only) ---
# The LGTM stack (Loki/Grafana/Tempo/Prometheus/Alertmanager) — never part of a real deploy
# (see deploy/base/platform-observability's own "offline-validated only" note).
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3002
LOKI_PORT=3100
TEMPO_HTTP_PORT=3200
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318
WEBHOOK_CATCHER_PORT=9099
# Every Go service's own OpenTelemetry exporter — defaults to Tempo's OTLP/HTTP port above.
# OTEL_SERVICE_NAME defaults to each service's own name; only set it to override.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=
